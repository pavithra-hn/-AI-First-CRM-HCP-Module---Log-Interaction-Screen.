# Environment Variables
GROQ_API_KEY=your_groq_api_key_here
DATABASE_URL=postgresql://crm_user:crm_password_2024@localhost:5432/crm_hcp

# LLM model (Groq).
# NOTE: The assignment specified `gemma2-9b-it`, but Groq has decommissioned that
# model (API now returns HTTP 400). We use `llama-3.3-70b-versatile`, which the
# assignment explicitly permits and which supports the agent's tool-calling.
LLM_MODEL=llama-3.3-70b-versatile
LLM_MODEL_FALLBACK=llama-3.1-8b-instant
